# Firebase Configuration
# Get these values from your Firebase project settings
# Note: REACT_APP_API_KEY is designed to be public and is restricted via Firebase security rules

REACT_APP_API_KEY=your_firebase_api_key_here
REACT_APP_AUTH_DOMAIN=your_firebase_auth_domain_here
REACT_APP_PROJECT_ID=your_firebase_project_id_here
REACT_APP_STORAGE_BUCKET=your_firebase_storage_bucket_here
REACT_APP_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
REACT_APP_APP_ID=your_firebase_app_id_here
